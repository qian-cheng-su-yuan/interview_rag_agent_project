# ========== App ==========
APP_NAME=Enterprise RAG Agent
APP_ENV=local
API_HOST=127.0.0.1
API_PORT=8000

# ========== Storage ==========
KNOWLEDGE_BASE_DIR=data/knowledge_base
UPLOAD_DIR=data/uploads
STORAGE_DIR=storage
CHUNK_STORE_PATH=storage/chunks.json
QA_LOG_PATH=storage/qa_log.jsonl

# ========== RAG ==========
CHUNK_SIZE=600
CHUNK_OVERLAP=80
TOP_K=4

# ========== LLM ==========
# 没有 API Key 时，系统会使用本地兜底回答，便于面试演示。
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus
LLM_TIMEOUT=60
